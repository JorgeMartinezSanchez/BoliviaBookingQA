              "});\r",
              "\r",
              "pm.test(\"HU-01 | La respuesta contiene un token de acceso\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData).to.have.property(\"token\");\r",
              "    pm.expect(jsonData.token).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"HU-01 | El token se almacena correctamente en el entorno\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.token, \"No hay token para almacenar\").to.be.a(\"string\").and.not.empty;\r",
              "\r",
              "    pm.environment.set(\"auth_token\", jsonData.token);\r",
              "    pm.expect(pm.environment.get(\"auth_token\")).to.eql(jsonData.token);\r",
              "});\r",
              "\r",
              "const tokenGuardado = pm.environment.get(\"auth_token\");\r",
              "if (!tokenGuardado || tokenGuardado.trim() === \"\") {\r",
              "    pm.environment.unset(\"auth_token\");\r",
              "    pm.execution.setNextRequest(null);\r",
              "    console.error(\"HU-01 FALLIDO: Token no generado. Se abortan las pruebas posteriores.\");\r",
              "}"
            ],
